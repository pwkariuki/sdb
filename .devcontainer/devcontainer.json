{
  "name": "sdb",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt", "seccomp=unconfined"
  ],
  "forwardPorts": [2222],
  "appPort": [2222],
  "customizations": {
    "clion": {
      "toolchain": {
        "type": "remote",
        "host": "localhost",
        "port": 2222,
        "username": "root",
        "password": "password"
      }
    }
  },
  "postCreateCommand": "echo 0 > /proc/sys/kernel/yama/ptrace_scope || true"
}
